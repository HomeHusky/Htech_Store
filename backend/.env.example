# Required
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME
JWT_SECRET=change-me-to-a-long-random-secret
CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# Public URLs, used by Google OAuth redirects.
BACKEND_PUBLIC_URL=http://localhost:8000
FRONTEND_PUBLIC_URL=http://localhost:3000

# Runtime
APP_ENV=development
APP_DEBUG=true
HOST=0.0.0.0
PORT=8000

# Static uploads
STATIC_DIR=static
UPLOAD_DIR=static/uploads

# LLMs and embeddings
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENAI_TEXT_EMBED_3_SMALL=
PHI4_API_KEY=
PHI4_REASONING_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Google OAuth fallback. Admin can also edit these in /admin/notifications.
CLIENT_ID=
CLIENT_SECRET=

# Search
EMBEDDING_DIMENSION=768
HYBRID_RRF_K=60
HYBRID_LIMIT=8

# First local development admin bootstrap only
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@htech.vn
ADMIN_PASSWORD=change-me
